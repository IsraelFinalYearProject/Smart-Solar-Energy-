//FUNCTION TO GET TARIFF 
void getTariff() {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  http.begin(client, supabase_url);
  http.addHeader("apikey", supabase_anon_key);
  http.addHeader("Authorization",
                 String("Bearer ") + supabase_anon_key);
  int httpCode = http.GET();
  if (httpCode == HTTP_CODE_OK) {
    String response = http.getString();
    StaticJsonDocument<128> doc;
    if (!deserializeJson(doc, response)) {
      int tariff = doc["tariff"];
      Serial.print("<TARIFF:");
      Serial.print(tariff);
      Serial.println(">");
    }
  }
  http.end();
}
//FUNCTION TO SEND ENERGY TO WEBSITE 
void sendToSupabase(float energyValue, float tariffValue) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  http.begin(client, supabase_url);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("apikey", supabase_anon_key);
  http.addHeader("Authorization",
                 String("Bearer ") + supabase_anon_key);
  StaticJsonDocument<200> doc;
  doc["energy"] = energyValue;
 doc["tariff"] = tariffValue;
  String payload;
  serializeJson(doc, payload);
  int httpCode = http.POST(payload);
  Serial.print("POST CODE: ");
  Serial.println(httpCode);
  http.end();
}
